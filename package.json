{
  "name": "marginbase",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "corepack pnpm -r run build",
    "lint": "corepack pnpm -r run lint",
    "test": "corepack pnpm -r run test",
    "test:unit": "corepack pnpm -r --filter ./packages/* run test",
    "test:coverage": "corepack pnpm --filter @marginbase/domain-core run test:coverage && corepack pnpm --filter @marginbase/reporting run test:coverage",
    "test:e2e": "playwright test",
    "typecheck": "corepack pnpm -r run typecheck",
    "boot:web": "corepack pnpm --filter @marginbase/web boot",
    "boot:mobile": "corepack pnpm --filter @marginbase/mobile boot"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "1.58.2",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.21.0",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "vitest": "^3.0.8"
  }
}
