{
  "name": "marginbase",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "corepack pnpm -r run build",
    "lint": "corepack pnpm -r run lint",
    "test": "corepack pnpm -r run test",
    "test:unit": "corepack pnpm -r --filter ./packages/* run test",
    "test:coverage": "corepack pnpm --filter @marginbase/domain-core run test:coverage && corepack pnpm --filter @marginbase/reporting run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:all": "corepack pnpm --filter @marginbase/testkit build && playwright test",
    "test:deterministic": "corepack pnpm test && corepack pnpm test && corepack pnpm test",
    "i18n:parity": "corepack pnpm exec tsx scripts/i18n-key-parity.ts",
    "typecheck": "corepack pnpm -r run typecheck",
    "boot:web": "corepack pnpm --filter @marginbase/web boot",
    "boot:mobile": "corepack pnpm --filter @marginbase/mobile boot",
    "check:console-logs": "tsx scripts/check-console-logs.ts",
    "check:bundle-size": "corepack pnpm --filter @marginbase/web build && du -sh apps/web/dist",
    "quality:report": "tsx scripts/quality-report.ts",
    "hooks:install": "git config core.hooksPath .githooks && echo Git hooks installed successfully!",
    "audit:security": "corepack pnpm audit --audit-level moderate",
    "validate:all": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm i18n:parity && corepack pnpm test && corepack pnpm test:coverage"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "1.58.2",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.21.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "vitest": "^3.0.8"
  }
}
