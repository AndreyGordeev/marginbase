{
  "name": "@marginbase/web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "main": "dist/main.js",
  "types": "src/main.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run --passWithNoTests --exclude tests/e2e/**",
    "test:e2e": "playwright test -c ../../playwright.config.ts",
    "test:visual": "playwright test tests/e2e/visual-regression.spec.ts -c ../../playwright.config.ts",
    "test:performance": "playwright test tests/e2e/performance.spec.ts -c ../../playwright.config.ts",
    "test:chaos": "playwright test tests/e2e/chaos.spec.ts -c ../../playwright.config.ts",
    "test:load": "playwright test tests/e2e/load-test.spec.ts -c ../../playwright.config.ts",
    "test:security": "playwright test tests/e2e/security.spec.ts -c ../../playwright.config.ts",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts -c ../../playwright.config.ts",
    "test:lighthouse": "playwright test tests/e2e/lighthouse-audit.spec.ts -c ../../playwright.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "boot": "node dist/main.js"
  },
  "dependencies": {
    "@marginbase/api-client": "workspace:*",
    "@marginbase/domain-core": "workspace:*",
    "@marginbase/entitlements": "workspace:*",
    "@marginbase/reporting": "workspace:*",
    "@marginbase/storage": "workspace:*",
    "@marginbase/telemetry": "workspace:*",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^26.1.0",
    "vite": "^7.1.11"
  }
}
